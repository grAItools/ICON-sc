[importlinter]
root_packages =
    icon_sc.core
    icon_sc.icon
    icon_sc.bridges

; The composition layer is model-agnostic; ICON is a client of it (layout doc §0).
[importlinter:contract:core-independence]
name = icon_sc.core must not import icon_sc.icon or icon_sc.bridges
type = forbidden
source_modules =
    icon_sc.core
forbidden_modules =
    icon_sc.icon
    icon_sc.bridges

; Bridge components arrive via the component registry: scheme selection is a config
; string, not an import (layout doc §5).
[importlinter:contract:icon-no-bridges]
name = icon_sc.icon must not import icon_sc.bridges
type = forbidden
source_modules =
    icon_sc.icon
forbidden_modules =
    icon_sc.bridges
