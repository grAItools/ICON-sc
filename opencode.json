{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "allow",
    "bash": {
      "uv *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "mypy *": "allow",
      "lint-imports*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git switch *": "allow",
      "git clone --depth 1 *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "mpirun -n 4 *": "allow",
      "git push*": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "*": "ask"
    }
  }
}
